        ctx.beginPath(); ctx.moveTo(330, 120); ctx.lineTo(380, 150); ctx.lineTo(380, 362); ctx.lineTo(330, 392); ctx.fill(); // Windshield
        ctx.beginPath(); ctx.moveTo(180, 120); ctx.lineTo(130, 150); ctx.lineTo(130, 362); ctx.lineTo(180, 392); ctx.fill(); // Rear
        ctx.fillRect(200, 30, 120, 50); // Left Window
