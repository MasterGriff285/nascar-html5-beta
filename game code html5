// Input State
let isPaused = false, gameState = 'START', raceTimer = 0, lastTime = performance.now();
const keys = { w: false, a: false, s: false, d: false, ArrowUp: false, ArrowDown: false, ArrowLeft: false, ArrowRight: false };

const DRIVER_NAMES = ["Chase", "Kyle L.", "Joey", "Ryan", "Denny", "Martin", "William", "Tyler", "Brad", "Ross", "Christopher", "Kevin", "Bubba", "Alex", "Ty", "Daniel", "Chris", "Austin D.", "Michael", "John", "Erik", "Aric", "Harrison", "Ricky", "Corey", "Todd", "Justin", "Noah", "Ryan P.", "AJ", "Zane", "Josh", "Riley", "Kaz", "Carson", "Jimmie", "Dale", "Jeff", "Tony", "Richard"];

