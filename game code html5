        this.isPitting = false; this.pitBoxDist = 1000 + this.id * 150; this.pitTimer = 0; this.pitServices = { damage: false, fuel: false, tires: false };
        this.targetLane = 0; this.baseLane = (Math.random() - 0.5) * 0.6; this.aiAggression = this.bravery; this.wobble = 0; this.draftingAmount = 0; this.panicTimer = 0;
    }

    createCarTexture() {
        let c = document.createElement('canvas'); c.width = 512; c.height = 512; let ctx = c.getContext('2d');
        ctx.fillStyle = this.colorStr; ctx.fillRect(0,0,512,512);
        ctx.fillStyle = '#111'; ctx.fillRect(0, 200, 512, 112); 
        ctx.fillStyle = '#fff'; ctx.fillRect(470, 100, 20, 60); ctx.fillRect(470, 352, 20, 60); 
        ctx.fillStyle = '#000'; ctx.fillRect(490, 190, 22, 132);
        ctx.fillStyle = '#f00'; ctx.fillRect(20, 100, 25, 60); ctx.fillRect(20, 352, 25, 60);
        
