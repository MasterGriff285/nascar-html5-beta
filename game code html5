        let trackBaseHeight = (hFL + hFR + hRL + hRR) / 4;
        
        let hFront = (hFL + hFR) / 2; let hBack = (hRL + hRR) / 2;
        let targetPitch = Math.atan2(hFront - hBack, this.length);
        
        let hLeft = (hFL + hRL) / 2; let hRight = (hFR + hRR) / 2;
        let targetRoll = Math.atan2(hRight - hLeft, this.width);

        this.mesh.position.set(this.pos.x, trackBaseHeight + this.heightZ, -this.pos.y);
        this.mesh.rotation.order = 'YXZ';
        this.mesh.rotation.y = this.angle; 
        this.mesh.rotation.z = this.pitch + targetPitch;
        this.mesh.rotation.x = this.roll + targetRoll; 
        
        if (this.damaged && Math.random() < 0.1 && speed > 50 && !this.isAirborne) {
            spawnSmoke(this.pos, this.vel); this.mesh.children[0].material.color.setHex(0x555555); 
        }

        if (forwardVel > 0 && !this.isAirborne) this.raceDistance += speedMps * dt * 10; 
        if (this.raceDistance > totalTrackLength) { this.raceDistance -= totalTrackLength; this.lap++; }
    }

    doAI(dt, cars) {
        let inputs = { throttle: false, brake: false, steer: 0 };
        if (this.health <= 0) return inputs;

        let mySpeed = this.vel.mag(); let speedMph = mySpeed * 0.223694;

        if (!this.isPitting && !this.isPlayer) {
            if (this.fuel < 10 || this.tires < 15 || this.health < 40) {
                this.isPitting = true; this.pitServices = { fuel: true, tires: true, damage: this.health < 50 }; this.pitTimer = 5;
            }
        }

        if (this.isPitting) {
            let isNearPits = this.raceDistance > totalTrackLength - 6000 || this.raceDistance < 8000;
            let distToBox = this.pitBoxDist - this.raceDistance;
            while (distToBox < -totalTrackLength/2) distToBox += totalTrackLength;
            while (distToBox > totalTrackLength/2) distToBox -= totalTrackLength;
            
            if (isNearPits) {
                this.targetLane = 2.0; let targetSpeed = 55; 
                if (distToBox > 0 && distToBox < 400) targetSpeed = 0; 
                else if (distToBox < 0 && distToBox > -200) targetSpeed = 45; 
                
                if (speedMph > targetSpeed + 2) { inputs.brake = true; inputs.throttle = false; } 
                else if (speedMph < targetSpeed - 2 && distToBox > 5) { inputs.throttle = true; inputs.brake = false; } 
                else if (distToBox <= 5 && distToBox >= -5 && speedMph < 5) {
                    inputs.brake = true; inputs.throttle = false; this.pitTimer -= dt;
                    if (this.pitTimer <= 0) {
                        if (this.pitServices.fuel) this.fuel = 100; if (this.pitServices.tires) this.tires = 100;
                        if (this.pitServices.damage) { 
                            this.health = 100; this.damaged = false; this.mesh.children[0].material.color.setHex(0xffffff);
                            let positions = this.bodyGeo.attributes.position; let orig = this.bodyGeoOrig; 
                            for(let i=0; i<positions.count; i++) positions.setXYZ(i, orig[i*3], orig[i*3+1], orig[i*3+2]);
                            positions.needsUpdate = true; this.bodyGeo.computeVertexNormals();
                        }
                        this.isPitting = false; 
                    }
                } else if (distToBox < 0) { inputs.throttle = true; inputs.brake = false; } 
                else { inputs.throttle = false; inputs.brake = true; }
            } else { this.targetLane = 1.0; inputs.throttle = true; if (speedMph > 150) inputs.brake = true; }
            
            let targetTrack = getTrackPosByDistance(this.raceDistance + 300);
            let finalTargetPos = targetTrack.pos.add(targetTrack.normal.mult((this.targetLane) * TRACK_WIDTH * 0.4));
            let toTarget = finalTargetPos.sub(this.pos);
            let targetAngle = Math.atan2(toTarget.y, toTarget.x);
            let angleDiff = targetAngle - this.angle;
            while (angleDiff > Math.PI) angleDiff -= Math.PI * 2; while (angleDiff < -Math.PI) angleDiff += Math.PI * 2;
            inputs.steer = Math.max(-1, Math.min(1, angleDiff * 5.0));
            return inputs; 
        }

        let forward = new Vec2(Math.cos(this.angle), Math.sin(this.angle));
        let lookAheadDist = 500 + mySpeed * (1.2 + this.skill * 0.4); 
        let targetTrack = getTrackPosByDistance(this.raceDistance + lookAheadDist);
        
        let carAhead = null, distAhead = Infinity, carLeft = false, carRight = false, panic = false;
        this.draftingAmount = 0;

        for (let other of cars) {
            if (other === this || other.health <= 0 || other.isPitting) continue;
            let toOther = other.pos.sub(this.pos); let dist = toOther.mag(); if (dist > 3000) continue;

            let fwdDot = toOther.normalize().dot(forward);
            let rightDot = toOther.normalize().dot(new Vec2(-Math.sin(this.angle), Math.cos(this.angle)));

            if (fwdDot > 0.8) {
                if (dist < distAhead && Math.abs(rightDot) * dist < this.width * 1.5) {
                    carAhead = other; distAhead = dist;
                    if (dist < 1200 && fwdDot > 0.95) this.draftingAmount = 1.0 - (dist / 1200);
                }
                let otherSpeed = other.vel.mag(); let otherSlip = Math.abs(Math.sin(other.angle - Math.atan2(other.vel.y, other.vel.x)));
                if (dist < 2500 && (otherSpeed < mySpeed - 100 || otherSlip > 0.25)) { if (Math.abs(rightDot) * dist < this.width * 5) panic = true; }
            }
            if (Math.abs(fwdDot) < 0.5 && dist < this.length * 3.5) {
                if (rightDot < 0) carLeft = true; if (rightDot > 0) carRight = true;
            }
        }

        if (panic) this.panicTimer = 0.4; 

        if (this.panicTimer > 0) {
            this.panicTimer -= dt; inputs.brake = true;
            let trackNormal = getTrackPosByDistance(this.raceDistance).normal;
            let mySide = this.pos.sub(getTrackPosByDistance(this.raceDistance).pos).dot(trackNormal);
            this.targetLane = mySide > 0 ? 1 : -1; 
        } else {
            inputs.throttle = true;
            if (carAhead && distAhead < 1200 && carAhead.vel.mag() < mySpeed + 15) {
                if (this.targetLane <= 0 && !carRight) this.targetLane += 0.4 * this.bravery; 
                else if (this.targetLane >= 0 && !carLeft) this.targetLane -= 0.4 * this.bravery; 
                else { inputs.throttle = false; if (distAhead < 300) inputs.brake = true; }
            } else { this.targetLane = this.targetLane * 0.98 + this.baseLane * 0.02; }
        }

        if (Math.random() < 0.0001 * this.aiAggression) {
            this.wobble = (Math.random() - 0.5) * 0.3;
        }
        this.wobble *= 0.95;

        this.targetLane = Math.max(-0.6, Math.min(0.6, this.targetLane));
        let finalTargetPos = targetTrack.pos.add(targetTrack.normal.mult((this.targetLane + this.wobble) * TRACK_WIDTH * 0.4));
        let toTarget = finalTargetPos.sub(this.pos);
        let targetAngle = Math.atan2(toTarget.y, toTarget.x);
        let angleDiff = targetAngle - this.angle;
        while (angleDiff > Math.PI) angleDiff -= Math.PI * 2; while (angleDiff < -Math.PI) angleDiff += Math.PI * 2;
        inputs.steer = Math.max(-1, Math.min(1, angleDiff * 5.0));

        return inputs;
    }
}

/** COLLISION SYSTEM */
function checkCollisions(cars) {
    for (let i = 0; i < cars.length; i++) {
        let c = cars[i];
        let tInfo = getTrackPosByDistance(c.raceDistance);
        let distFromCenter = c.pos.sub(tInfo.pos).dot(tInfo.normal);
        let halfTrack = TRACK_WIDTH / 2; let carPad = c.width / 2;
        
        // Outer Wall
        if (!c.isPitting && distFromCenter < -halfTrack + carPad) {
            let overlap = (-halfTrack + carPad) - distFromCenter;
            c.pos = c.pos.add(tInfo.normal.mult(overlap)); 
            let velAlongNormal = c.vel.dot(tInfo.normal);
            if (velAlongNormal < 0) {
                c.vel = c.vel.add(tInfo.normal.mult(-velAlongNormal * 1.2));
                let tangent = new Vec2(-tInfo.normal.y, tInfo.normal.x);
                let vT = c.vel.dot(tangent); c.vel = c.vel.sub(tangent.mult(vT * 0.05));
                let impact = Math.abs(velAlongNormal); c.health -= impact * 0.2;
                if (c.health < 50) c.damaged = true;
                if (impact > 50) {
                    spawnSparks(c.pos.add(tInfo.normal.mult(-c.width/2)), tInfo.normal, 15);
                    if (Math.random() < 0.2) spawnDebris(c.pos, c.vel, c.colorStr, 1);
                }
                applyDeformation(c, c.pos.add(tInfo.normal.mult(-c.width/2)), impact * 150, tInfo.normal);
            }
        }
        
        // Inner Grass Wall - Prevents cutting the course (DYNAMIC OPENING IN PIT ROAD ENTRY/EXIT)
        let inPitZone = (c.raceDistance > totalTrackLength - 4000 || c.raceDistance < 8500);
        let innerLimit = halfTrack + 10; 
        
        if (c.isPitting && inPitZone) {
            // FIX: Wall limit expanded to 245 units. Unlocks pit entry without collision blockage!
            innerLimit = halfTrack + 120; 
        }
        
        if (distFromCenter > innerLimit - carPad) {
            let overlap = distFromCenter - (innerLimit - carPad);
            let pushNormal = tInfo.normal.mult(-1);
            c.pos = c.pos.add(pushNormal.mult(overlap));
            let velN = c.vel.dot(pushNormal);
            if (velN < 0) {
                c.vel = c.vel.add(pushNormal.mult(-velN * 1.1));
                c.vel = c.vel.mult(0.95); // Dirt friction drag
            }
        }

        // Car-to-Car check
        for (let j = i + 1; j < cars.length; j++) {
            let cA = cars[i], cB = cars[j];
            if (cA.pos.sub(cB.pos).mag() > 15 * METER) continue;
            let result = satCollide(cA, cB);
            if (result.collided) resolveCollision(cA, cB, result);
        }
    }
}

function getAxes(corners) {
    let axes = [];
    for (let i = 0; i < corners.length; i++) {
        let p1 = corners[i], p2 = corners[(i + 1) % corners.length];
        let edge = p1.sub(p2); axes.push(new Vec2(-edge.y, edge.x).normalize());
    } return axes;
}

function project(corners, axis) {
    let min = corners[0].dot(axis), max = min;
    for (let i = 1; i < corners.length; i++) {
        let p = corners[i].dot(axis); if (p < min) min = p; if (p > max) max = p;
    } return { min, max };
}

function satCollide(cA, cB) {
    // Deep penetration check to stop any clipping/getting stuck inside cars
    let centerToCenter = cB.pos.sub(cA.pos);
    let dist = centerToCenter.mag();
    if (dist < cA.width * 0.85) { 
        return { 
            collided: true, 
            normal: centerToCenter.normalize(), 
            overlap: cA.width - dist + 6, 
            contactPoint: cA.pos.add(cB.pos).mult(0.5) 
        };
    }

    let cornersA = cA.getCorners(), cornersB = cB.getCorners();
    let axes = getAxes(cornersA).concat(getAxes(cornersB));
    let minOverlap = Infinity, smallestAxis = null;

    for (let axis of axes) {
        let projA = project(cornersA, axis), projB = project(cornersB, axis);
        if (projA.max < projB.min || projB.max < projA.min) return { collided: false };
        let overlap = Math.min(projA.max, projB.max) - Math.max(projA.min, projB.min);
        if (overlap < minOverlap) { minOverlap = overlap; smallestAxis = axis; }
    }
    if (cB.pos.sub(cA.pos).dot(smallestAxis) < 0) smallestAxis = smallestAxis.mult(-1);
    return { collided: true, normal: smallestAxis, overlap: minOverlap, contactPoint: cA.pos.add(cB.pos).mult(0.5) };
}

function resolveCollision(cA, cB, hit) {
    // Radial separation correction
    let correctionMag = hit.overlap * 0.95;
    let correction = hit.normal.mult(correctionMag);
    cA.pos = cA.pos.sub(correction.mult(0.5)); 
    cB.pos = cB.pos.add(correction.mult(0.5));

    let rA = hit.contactPoint.sub(cA.pos), rB = hit.contactPoint.sub(cB.pos);
    let vA = cA.vel.add(new Vec2(-rA.y, rA.x).mult(cA.angularVel));
    let vB = cB.vel.add(new Vec2(-rB.y, rB.x).mult(cB.angularVel));
    
    let relVel = vB.sub(vA); let velAlongNormal = relVel.dot(hit.normal);
    if (velAlongNormal > 0) return; 

    let invMassA = 1/cA.mass, invMassB = 1/cB.mass;
    let invInertiaA = 1/cA.inertia, invInertiaB = 1/cB.inertia;
    let rA_cross_n = rA.cross(hit.normal), rB_cross_n = rB.cross(hit.normal);

    let j = -(1 + 0.1) * velAlongNormal; 
    let denom = invMassA + invMassB + (rA_cross_n * rA_cross_n) * invInertiaA + (rB_cross_n * rB_cross_n) * invInertiaB;
    j = Math.min(j / denom, 180000); 

    let impulse = hit.normal.mult(j);
    cA.vel = cA.vel.sub(impulse.mult(invMassA)); cB.vel = cB.vel.add(impulse.mult(invMassB));
    cA.angularVel -= rA.cross(impulse) * invInertiaA; cB.angularVel += rB.cross(impulse) * invInertiaB;

    let tangent = relVel.sub(hit.normal.mult(velAlongNormal));
    if (tangent.mag() > 0.01) {
        tangent = tangent.normalize(); let jt = -relVel.dot(tangent);
        let rA_cross_t = rA.cross(tangent), rB_cross_t = rB.cross(tangent);
        let denomT = invMassA + invMassB + (rA_cross_t * rA_cross_t) * invInertiaA + (rB_cross_t * rB_cross_t) * invInertiaB;
        jt = Math.max(-j * 0.15, Math.min(j * 0.15, jt / denomT)); 
        
        let frictionImpulse = tangent.mult(jt);
        cA.vel = cA.vel.sub(frictionImpulse.mult(invMassA)); cB.vel = cB.vel.add(frictionImpulse.mult(invMassB));
        cA.angularVel -= rA.cross(frictionImpulse) * invInertiaA; cB.angularVel += rB.cross(frictionImpulse) * invInertiaB;
    }

    if (j > 10000) {
        cA.health -= j * 0.0012; cB.health -= j * 0.0012;
        if(cA.health < 50) cA.damaged = true; if(cB.health < 50) cB.damaged = true;
        spawnSparks(hit.contactPoint, hit.normal, Math.min(40, j*0.001));
        
        applyDeformation(cA, hit.contactPoint, j, hit.normal.mult(-1)); 
        applyDeformation(cB, hit.contactPoint, j, hit.normal);
        
        // Spawn debris on high impact
        if (j > 25000 && Math.random() < 0.4) {
            spawnDebris(hit.contactPoint, cA.vel, cA.colorStr, 2);
            spawnDebris(hit.contactPoint, cB.vel, cB.colorStr, 2);
        }

        // TRIGGER BLOWOVER / BARREL ROLL ROTATIONS ON SEVERE CRASHES
        if (j > 45000) {
            let sideA = Math.abs(hit.normal.dot(new Vec2(-Math.sin(cA.angle), Math.cos(cA.angle))));
            if (sideA > 0.5 && cA.vel.mag() > 100 && !cA.isAirborne) {
                cA.isAirborne = true; cA.velZ = 35 + Math.random() * 20; 
                cA.rollVel = (Math.random() > 0.5 ? 1 : -1) * (12 + Math.random() * 12); 
                cA.pitchVel = (Math.random() - 0.5) * 6;
            }
            let sideB = Math.abs(hit.normal.dot(new Vec2(-Math.sin(cB.angle), Math.cos(cB.angle))));
            if (sideB > 0.5 && cB.vel.mag() > 100 && !cB.isAirborne) {
                cB.isAirborne = true; cB.velZ = 35 + Math.random() * 20; 
                cB.rollVel = (Math.random() > 0.5 ? 1 : -1) * (12 + Math.random() * 12); 
                cB.pitchVel = (Math.random() - 0.5) * 6;
            }
        }
    }
}

function applyDeformation(car, contactPoint, impulseMag, worldNormal) {
    if (!car.bodyGeo) return;
    let toContact = contactPoint.sub(car.pos); let localContact = toContact.rotate(-car.angle); let localNormal = worldNormal.rotate(-car.angle);
    let positions = car.bodyGeo.attributes.position; let v = new THREE.Vector3(); let damageDone = false;
    let crushFactor = Math.min(impulseMag * 0.0008, 20); let impactRadius = 24; 

    for (let i = 0; i < positions.count; i++) {
        v.fromBufferAttribute(positions, i);
        let dist = Math.sqrt(Math.pow(v.x - localContact.x, 2) + Math.pow(v.z - (-localContact.y), 2));
        if (dist < impactRadius) { 
            let forceMultiplier = Math.pow(Math.cos((dist / impactRadius) * (Math.PI / 2)), 1.5); 
            let crinkleNoise = (Math.sin(v.x * 1.5) * Math.cos(v.z * 1.5)) * 0.8;
            let push = crushFactor * forceMultiplier + crinkleNoise;
            
            v.x += localNormal.x * push; v.z += (-localNormal.y) * push; 
            let buckleDir = (dist < impactRadius * 0.4) ? 1.5 : -0.5; v.y += push * 0.3 * buckleDir;
            v.x = Math.max(-car.length/2, Math.min(car.length/2, v.x)); v.z = Math.max(-car.width/2, Math.min(car.width/2, v.z));
            positions.setXYZ(i, v.x, v.y, v.z); damageDone = true;
        }
    }
    if (damageDone) { positions.needsUpdate = true; car.bodyGeo.computeVertexNormals(); }
}

/** GAME ENGINE LOOP */
let cars = [];

function initGame() {
    buildTrackData(); build3DMeshes(); cars = [];
    let startDist = TRACK_STRAIGHT - 1000; 
    for (let i = 0; i < 40; i++) {
        let isPlayer = i === 20; let row = Math.floor(i / 2); let lane = (i % 2 === 0) ? -0.4 : 0.4; 
        cars.push(new Car(i, isPlayer, startDist - (row * 80), lane));
    }
    gameState = 'START'; raceTimer = -3; 
}

function update() {
    if (isPaused) return;
    let now = performance.now(); let dt = (now - lastTime) / 1000; lastTime = now; if (dt > 0.1) dt = 0.1; 
    raceTimer += dt;
    
    let msgEl = document.getElementById('messages');
    if (gameState === 'START') {
        msgEl.style.opacity = 1;
        if (raceTimer < -2) msgEl.innerText = "3";
        else if (raceTimer < -1) msgEl.innerText = "2";
        else if (raceTimer < 0) msgEl.innerText = "1";
        else { msgEl.innerText = "GREEN FLAG!"; gameState = 'RACE'; setTimeout(() => { msgEl.style.opacity = 0; }, 2000); }
    }

    let isRacing = (gameState === 'RACE');
    for (let i = particles.length - 1; i >= 0; i--) { particles[i].update(dt); if (particles[i].life <= 0) particles.splice(i, 1); }
    for (let i = debrisList.length - 1; i >= 0; i--) { debrisList[i].update(dt); if (debrisList[i].life <= 0) debrisList.splice(i, 1); }

    cars.sort((a, b) => { return (b.lap * totalTrackLength + b.raceDistance) - (a.lap * totalTrackLength + a.raceDistance); });

    let playerPos = 1, pCar = null;
    for (let i = 0; i < cars.length; i++) {
        let c = cars[i]; if (c.isPlayer) { playerPos = i + 1; pCar = c; }
        if (isRacing) {
            if (c.isPlayer && !c.isPitting) {
                let targetSteer = 0;
                if (keys.a || keys.ArrowLeft) targetSteer += 1; if (keys.d || keys.ArrowRight) targetSteer -= 1; 
                c.steerInput = (c.steerInput || 0); c.steerInput += (targetSteer - c.steerInput) * 12 * dt;
                c.currentInputs = { throttle: (keys.w || keys.ArrowUp), brake: (keys.s || keys.ArrowDown), steer: c.steerInput };
            } else c.currentInputs = c.doAI(dt, cars);
        } else c.currentInputs = { throttle: false, brake: false, steer: 0 };
    }

    let steps = 8; let subDt = dt / steps;
    for (let s = 0; s < steps; s++) {
        for (let c of cars) c.updatePhysics(subDt, c.currentInputs);
        if (isRacing) checkCollisions(cars);
    }

    if (pCar) {
        let idealX = pCar.mesh.position.x - Math.cos(pCar.angle) * 100;
        let idealZ = pCar.mesh.position.z + Math.sin(pCar.angle) * 100;
        let idealY = pCar.mesh.position.y + 30; 

        let speedMph = pCar.vel.mag() * 0.223694; 
        if (speedMph > 180 && !pCar.isPitting) {
            let shake = (speedMph - 180) * 0.05;
            idealX += (Math.random() - 0.5) * shake; idealY += (Math.random() - 0.5) * shake; idealZ += (Math.random() - 0.5) * shake;
        }

        camera.position.x += (idealX - camera.position.x) * 10 * dt;
        camera.position.y += (idealY - camera.position.y) * 10 * dt;
        camera.position.z += (idealZ - camera.position.z) * 10 * dt;
        
        let lookX = pCar.mesh.position.x + Math.cos(pCar.angle) * 150;
        let lookZ = pCar.mesh.position.z - Math.sin(pCar.angle) * 150;
        camera.lookAt(lookX, pCar.mesh.position.y, lookZ);
        
        let targetFov = 70 + (speedMph / 200) * 15 + (pCar.draftingAmount * 15);
        camera.fov += (targetFov - camera.fov) * 5 * dt; camera.updateProjectionMatrix();

        document.getElementById('speed-val').innerText = Math.floor(speedMph);
        document.getElementById('pos-val').innerText = `${playerPos} - ${pCar.driverName}`;
        document.getElementById('lap-val').innerText = pCar.lap;
        document.getElementById('hud-fuel').innerText = Math.floor(pCar.fuel);
        document.getElementById('hud-tires').innerText = Math.floor(pCar.tires);
        document.getElementById('hud-dmg').innerText = Math.floor(100 - pCar.health);

        let draftUI = document.getElementById('draft-indicator');
        draftUI.style.opacity = (pCar.draftingAmount > 0.5 && speedMph > 100 && !pCar.isPitting) ? 1 : 0;

        if (pCar.isPitting) { msgEl.innerText = "PIT SPEED LIMIT 55 MPH\nAUTO-DRIVING..."; msgEl.style.opacity = 1; } 
        else if (pCar.lap > TOTAL_LAPS && gameState === 'RACE') { gameState = 'END'; msgEl.innerText = "CHECKERED FLAG!\nFinished " + playerPos; msgEl.style.opacity = 1; } 
        else if (gameState === 'RACE' && raceTimer > 2) msgEl.style.opacity = 0;
    }
}

function drawMinimap() {
    miniCtx.clearRect(0, 0, miniCanvas.width, miniCanvas.height);
    let scaleX = miniCanvas.width / (TRACK_STRAIGHT + TRACK_RADIUS*2 + 1000); let scaleY = miniCanvas.height / (TRACK_RADIUS*2 + 1000);
    let scale = Math.min(scaleX, scaleY);
    miniCtx.save(); miniCtx.translate(miniCanvas.width/2, miniCanvas.height/2); miniCtx.scale(scale, scale);

    miniCtx.beginPath(); miniCtx.strokeStyle = '#555'; miniCtx.lineWidth = TRACK_WIDTH;
    for (let i = 0; i < waypoints.length; i++) {
        let p = waypoints[i].pos; if (i === 0) miniCtx.moveTo(p.x, p.y); else miniCtx.lineTo(p.x, p.y);
    } miniCtx.closePath(); miniCtx.stroke();

    for (let c of cars) {
        miniCtx.fillStyle = c.isPlayer ? '#ff0' : (c.damaged ? '#f00' : '#fff');
        let r = c.isPlayer ? 80 : 40; miniCtx.beginPath(); miniCtx.arc(c.pos.x, c.pos.y, r, 0, Math.PI*2); miniCtx.fill();
    } miniCtx.restore();
}

function loop() {
    update();
    if (!isPaused) { renderer.render(scene, camera); drawMinimap(); }
    requestAnimationFrame(loop);
}

initGame();
loop();
</script>
