    buildMesh() {
        this.mesh = new THREE.Group();
        this.bodyGeo = new THREE.BoxGeometry(this.length, 6, this.width, 24, 3, 10);
        
        // SCULPTING GEN 7 FASTBACK SHAPE
        let positions = this.bodyGeo.attributes.position;
        for (let i = 0; i < positions.count; i++) {
            let x = positions.getX(i), y = positions.getY(i), z = positions.getZ(i);
            let nx = x / this.length;
            if (y > 0) {
                if (nx > 0.25) y -= (nx - 0.25) * 12; // Sloped Nose
                else if (nx > 0.0) y += (nx) * 5;     // Windshield
                else if (nx > -0.2) y += 1.5;         // Flat roof
                else if (nx > -0.4) y -= (-nx - 0.2) * 15; // Fastback rear
                else y -= 3;                          // Decklid
                let nz = Math.abs(z) / (this.width / 2);
                y -= nz * nz * 1.5; // Tumblehome (round sides)
            }
            if (nx > 0.3) z *= 1.0 - (nx - 0.3) * 0.6; // Nose taper
            else if (nx < -0.4) z *= 1.0 - (-nx - 0.4) * 0.4; // Tail taper
