            this.angle += this.angularVel * dt; this.pos = this.pos.add(this.vel.mult(dt));
        }

        // PERFECT 4-WHEEL GROUND HEIGHT ALIGNMENT
        let tInfo = getTrackPosByDistance(this.raceDistance);
        let rightVec = new Vec2(-Math.sin(this.angle), Math.cos(this.angle));
        let fwdVec = new Vec2(Math.cos(this.angle), Math.sin(this.angle));
        let hw = this.width / 2; let hl = this.length / 2;
        
        let fl = this.pos.add(fwdVec.mult(hl)).add(rightVec.mult(-hw));
        let fr = this.pos.add(fwdVec.mult(hl)).add(rightVec.mult(hw));
        let rl = this.pos.sub(fwdVec.mult(hl)).add(rightVec.mult(-hw));
        let rr = this.pos.sub(fwdVec.mult(hl)).add(rightVec.mult(hw));

        let hFL = getTrackHeightAtPos(fl), hFR = getTrackHeightAtPos(fr);
