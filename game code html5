/** TRACK CONFIGURATION */
const METER = 10; 
const TRACK_STRAIGHT = 800 * METER; 
const TRACK_RADIUS = 300 * METER;   
const TRACK_WIDTH = 25 * METER;     
const TOTAL_LAPS = 10;

let waypoints = []; 
let totalTrackLength = 0;

function buildTrackData() {
    waypoints = [];
    const pointsCount = 300; 
    totalTrackLength = (TRACK_STRAIGHT * 2) + (2 * Math.PI * TRACK_RADIUS);
    const step = totalTrackLength / pointsCount;
    for (let i = 0; i < pointsCount; i++) {
        waypoints.push(getTrackPosByDistance(i * step));
    }
}

// SMOOTH BANKING INTERPOLATION
function getBankingAngle(d) {
    let maxBank = 0.54; // 31 deg
    let minBank = 0.08; // 4 deg
    let blend = 350 * METER; 
    
    let s1_s = 0, s1_e = TRACK_STRAIGHT;
    let t1_s = s1_e, t1_e = t1_s + Math.PI * TRACK_RADIUS;
    let s2_s = t1_e, s2_e = s2_s + TRACK_STRAIGHT;
    let t2_s = s2_e, t2_e = t2_s + Math.PI * TRACK_RADIUS;

    function smooth(t) { return t * t * (3 - 2 * t); }

    if (d >= s1_s && d < s1_e) {
        if (d < blend) return minBank + (maxBank - minBank) * smooth(1 - d/blend);
        if (d > s1_e - blend) return minBank + (maxBank - minBank) * smooth((d - (s1_e - blend))/blend);
        return minBank;
    } else if (d >= s2_s && d < s2_e) {
        let localD = d - s2_s;
        if (localD < blend) return minBank + (maxBank - minBank) * smooth(1 - localD/blend);
        if (localD > TRACK_STRAIGHT - blend) return minBank + (maxBank - minBank) * smooth((localD - (TRACK_STRAIGHT - blend))/blend);
        return minBank;
    } else {
        return maxBank;
    }
}

function getTrackPosByDistance(d) {
    d = d % totalTrackLength; if (d < 0) d += totalTrackLength;
    const arcLen = Math.PI * TRACK_RADIUS;
    let x, y, angle;

    if (d < TRACK_STRAIGHT) {
        x = (TRACK_STRAIGHT/2) - d; y = TRACK_RADIUS; angle = Math.PI;
    } else if (d < TRACK_STRAIGHT + arcLen) {
        let a = d - TRACK_STRAIGHT; let theta = Math.PI/2 + (a / TRACK_RADIUS);
        x = -TRACK_STRAIGHT/2 + Math.cos(theta) * TRACK_RADIUS; y = Math.sin(theta) * TRACK_RADIUS; angle = theta + Math.PI/2;
    } else if (d < TRACK_STRAIGHT * 2 + arcLen) {
        let a = d - (TRACK_STRAIGHT + arcLen);
        x = -TRACK_STRAIGHT/2 + a; y = -TRACK_RADIUS; angle = 0;
    } else {
        let a = d - (TRACK_STRAIGHT * 2 + arcLen); let theta = -Math.PI/2 + (a / TRACK_RADIUS);
        x = TRACK_STRAIGHT/2 + Math.cos(theta) * TRACK_RADIUS; y = Math.sin(theta) * TRACK_RADIUS; angle = theta + Math.PI/2;
    }
    return { 
        pos: new Vec2(x, y), tangent: new Vec2(Math.cos(angle), Math.sin(angle)),
        normal: new Vec2(-Math.sin(angle), Math.cos(angle)), distance: d, banking: getBankingAngle(d)
    };
}

// Projection utility to get the exact track distance 'd' of any 2D position
function getTrackDistAtPos(pos) {
    let closestWp = waypoints[0];
    let minDist = Infinity;
    for (let i = 0; i < waypoints.length; i += 5) {
        let d = waypoints[i].pos.sub(pos).mag();
        if (d < minDist) { minDist = d; closestWp = waypoints[i]; }
    }
    let idx = waypoints.indexOf(closestWp);
    let start = Math.max(0, idx - 10), end = Math.min(waypoints.length - 1, idx + 10);
    for (let i = start; i <= end; i++) {
        let d = waypoints[i].pos.sub(pos).mag();
        if (d < minDist) { minDist = d; closestWp = waypoints[i]; }
    }
    return closestWp.distance;
}

function getTrackHeightAtPos(pos) {
    let dist = getTrackDistAtPos(pos);
    let tInfo = getTrackPosByDistance(dist);
    let latOff = pos.sub(tInfo.pos).dot(tInfo.normal);
    return -latOff * Math.tan(tInfo.banking);
}

function build3DMeshes() {
    function createAsphalt() {
        let c = document.createElement('canvas'); c.width = 256; c.height = 256; let ctx = c.getContext('2d');
        ctx.fillStyle = '#2a2a2a'; ctx.fillRect(0,0,256,256);
        for(let i=0; i<2000; i++) { ctx.fillStyle = Math.random()>0.5?'#1a1a1a':'#3a3a3a'; ctx.fillRect(Math.random()*256, Math.random()*256, 2, 2); }
        let tex = new THREE.CanvasTexture(c); tex.wrapS = THREE.RepeatWrapping; tex.wrapT = THREE.RepeatWrapping; tex.repeat.set(300, 4);
        return new THREE.MeshLambertMaterial({ map: tex, side: THREE.DoubleSide });
    }
    function createWall() {
        let c = document.createElement('canvas'); c.width = 256; c.height = 256; let ctx = c.getContext('2d');
        ctx.fillStyle = '#ffffff'; ctx.fillRect(0,0,256,256); ctx.fillStyle = '#ffcc00'; ctx.fillRect(0, 100, 256, 40); 
        ctx.strokeStyle = '#cccccc'; ctx.lineWidth = 2; for(let i=0; i<256; i+=32) { ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, 256); ctx.stroke(); }
        let tex = new THREE.CanvasTexture(c); tex.wrapS = THREE.RepeatWrapping; tex.wrapT = THREE.RepeatWrapping; tex.repeat.set(600, 1);
        return new THREE.MeshLambertMaterial({ map: tex, side: THREE.DoubleSide });
    }
    function createFence() {
        let c = document.createElement('canvas'); c.width = 64; c.height = 64; let ctx = c.getContext('2d');
        ctx.fillStyle = 'rgba(0,0,0,0)'; ctx.fillRect(0,0,64,64); ctx.strokeStyle = 'rgba(150, 150, 150, 0.8)'; ctx.lineWidth = 2;
        ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(64,64); ctx.moveTo(64,0); ctx.lineTo(0,64); ctx.stroke();
        let tex = new THREE.CanvasTexture(c); tex.wrapS = THREE.RepeatWrapping; tex.wrapT = THREE.RepeatWrapping; tex.repeat.set(600, 6);
        return new THREE.MeshBasicMaterial({ map: tex, transparent: true, side: THREE.DoubleSide });
    }

    const tPos = [], tInd = [], tUvs = []; 
    const wPos = [], wInd = [], wUvs = []; 
    const fPos = [], fInd = [], fUvs = []; 
    const aPos = [], aInd = []; 
    const iPos = [], iInd = []; 
    
    let pts = waypoints.length;
    for(let i=0; i<pts; i++) {
        let wp = waypoints[i];
        let n = wp.normal; 
        
        let hIn = -(TRACK_WIDTH/2) * Math.tan(wp.banking);
        let hOut = -(-TRACK_WIDTH/2) * Math.tan(wp.banking);

        let pIn = wp.pos.add(n.mult(TRACK_WIDTH/2));   
        let pOut = wp.pos.add(n.mult(-TRACK_WIDTH/2)); 
        tPos.push(pIn.x, hIn, -pIn.y); tPos.push(pOut.x, hOut, -pOut.y);

        let pWallOut = wp.pos.add(n.mult(-TRACK_WIDTH/2 - 8));
        let hWallOut = -(-TRACK_WIDTH/2 - 8) * Math.tan(wp.banking);
        wPos.push(pOut.x, hOut, -pOut.y); wPos.push(pWallOut.x, hWallOut, -pWallOut.y);
        wPos.push(pOut.x, hOut + 12, -pOut.y); wPos.push(pWallOut.x, hWallOut + 12, -pWallOut.y);

        fPos.push(pOut.x, hOut + 12, -pOut.y); fPos.push(pOut.x, hOut + 40, -pOut.y);

        let pApronIn = wp.pos.add(n.mult(TRACK_WIDTH/2 + 60));
        let hApronIn = -(TRACK_WIDTH/2 + 60) * Math.tan(wp.banking);
        aPos.push(pApronIn.x, hApronIn, -pApronIn.y); aPos.push(pIn.x, hIn, -pIn.y);

        let pGrassIn = wp.pos.add(n.mult(TRACK_WIDTH/2 + 3000));
        iPos.push(pGrassIn.x, hApronIn, -pGrassIn.y); iPos.push(pApronIn.x, hApronIn, -pApronIn.y);
    }

    for(let i=0; i<pts; i++) {
        let next = (i+1)%pts; let i1=i*2, i2=i*2+1, n1=next*2, n2=next*2+1;
        tInd.push(i1, i2, n1, i2, n2, n1); aInd.push(i1, i2, n1, i2, n2, n1);
        iInd.push(i1, i2, n1, i2, n2, n1); fInd.push(i1, i2, n1, i2, n2, n1);
        let u1 = i/pts, u2 = next/pts;
        tUvs.push(u1, 0, u1, 1); fUvs.push(u1, 0, u1, 1);
        let w1=i*4, w2=i*4+1, w3=i*4+2, w4=i*4+3; let wn1=next*4, wn2=next*4+1, wn3=next*4+2, wn4=next*4+3;
        wInd.push(w1, w3, wn1, w3, wn3, wn1); wInd.push(w3, w4, wn3, w4, wn4, wn3); wInd.push(w4, w2, wn4, w2, wn2, wn4); 
        wUvs.push(u1, 0, u1, 0, u1, 1, u1, 1);
    }

    const tGeo = new THREE.BufferGeometry(); tGeo.setAttribute('position', new THREE.Float32BufferAttribute(tPos, 3)); tGeo.setAttribute('uv', new THREE.Float32BufferAttribute(tUvs, 2)); tGeo.setIndex(tInd); tGeo.computeVertexNormals();
    scene.add(new THREE.Mesh(tGeo, createAsphalt()));

    const wGeo = new THREE.BufferGeometry(); wGeo.setAttribute('position', new THREE.Float32BufferAttribute(wPos, 3)); wGeo.setAttribute('uv', new THREE.Float32BufferAttribute(wUvs, 2)); wGeo.setIndex(wInd); wGeo.computeVertexNormals();
    scene.add(new THREE.Mesh(wGeo, createWall()));

    const fGeo = new THREE.BufferGeometry(); fGeo.setAttribute('position', new THREE.Float32BufferAttribute(fPos, 3)); fGeo.setAttribute('uv', new THREE.Float32BufferAttribute(fUvs, 2)); fGeo.setIndex(fInd); fGeo.computeVertexNormals();
    scene.add(new THREE.Mesh(fGeo, createFence()));

    const aGeo = new THREE.BufferGeometry(); aGeo.setAttribute('position', new THREE.Float32BufferAttribute(aPos, 3)); aGeo.setIndex(aInd); aGeo.computeVertexNormals();
    scene.add(new THREE.Mesh(aGeo, new THREE.MeshLambertMaterial({ color: 0x555555, side: THREE.DoubleSide })));

    const iGeo = new THREE.BufferGeometry(); iGeo.setAttribute('position', new THREE.Float32BufferAttribute(iPos, 3)); iGeo.setIndex(iInd); iGeo.computeVertexNormals();
    scene.add(new THREE.Mesh(iGeo, new THREE.MeshLambertMaterial({ color: 0x1e4d1e, side: THREE.DoubleSide })));

    for (let i=0; i<40; i++) {
        let wp = getTrackPosByDistance(1000 + i * 150);
        let boxCenter = wp.pos.add(wp.normal.mult(TRACK_WIDTH/2 + 35));
        let hCenter = -(TRACK_WIDTH/2 + 35) * Math.tan(wp.banking) + 0.5; 
        const boxMesh = new THREE.Mesh(new THREE.PlaneGeometry(100, 30), new THREE.MeshBasicMaterial({ color: 0xcc0000, side: THREE.DoubleSide }));
        boxMesh.rotation.order = 'YXZ'; boxMesh.rotation.x = -Math.PI / 2; boxMesh.rotation.y = wp.banking; boxMesh.rotation.z = -Math.atan2(wp.tangent.y, wp.tangent.x);
        boxMesh.position.set(boxCenter.x, hCenter, -boxCenter.y);
        scene.add(boxMesh);
    }
}

/** PARTICLES & DEBRIS */
const particles = [];
const sparkGeo = new THREE.BoxGeometry(4, 4, 4);
const sparkMat = new THREE.MeshBasicMaterial({ color: 0xffaa00 });
const smokeMat = new THREE.MeshBasicMaterial({ color: 0x666666, transparent: true, opacity: 0.5 });

class Particle {
    constructor(pos, vel, isSmoke) {
        this.pos = pos.clone(); this.vel = vel; 
        this.life = isSmoke ? 1.5 : 0.5 + Math.random()*0.5; this.maxLife = this.life; this.isSmoke = isSmoke;
        this.mesh = new THREE.Mesh(sparkGeo, isSmoke ? smokeMat.clone() : sparkMat);
        let groundY = getTrackHeightAtPos(this.pos);
        this.mesh.position.set(pos.x, groundY + 2, -pos.y); scene.add(this.mesh);
    }
    update(dt) {
        this.pos = this.pos.add(this.vel.mult(dt));
        this.mesh.position.x = this.pos.x; this.mesh.position.z = -this.pos.y; this.mesh.position.y += (this.isSmoke ? 20 : 10) * dt; 
        this.life -= dt; let p = this.life / this.maxLife;
        if (this.isSmoke) { let s = 1 + (1 - p) * 3; this.mesh.scale.set(s,s,s); this.mesh.material.opacity = p * 0.5; } 
        else { this.mesh.scale.set(p,p,p); }
        if(this.life <= 0) { scene.remove(this.mesh); if(this.isSmoke) this.mesh.material.dispose(); }
    }
}
function spawnSparks(pos, normal, amount) { for(let i=0; i<amount; i++) particles.push(new Particle(pos, normal.mult(Math.random() * 200).add(new Vec2((Math.random()-0.5)*150, (Math.random()-0.5)*150)), false)); }
function spawnSmoke(pos, vel) { if(Math.random() > 0.3) return; particles.push(new Particle(pos, vel.mult(0.5).add(new Vec2((Math.random()-0.5)*50, (Math.random()-0.5)*50)), true)); }

const debrisList = [];
class Debris {
    constructor(pos, vel, color, type) {
        this.pos = pos.clone(); this.vel = vel; this.velZ = 30 + Math.random() * 50; 
        this.rotation = new THREE.Vector3(Math.random() * 6, Math.random() * 6, Math.random() * 6);
        this.rotVel = new THREE.Vector3((Math.random() - 0.5) * 12, (Math.random() - 0.5) * 12, (Math.random() - 0.5) * 12);
        this.life = 2.0 + Math.random() * 2.0; this.maxLife = this.life;
        
        let geom;
        if (type === 'spoiler') geom = new THREE.BoxGeometry(6, 0.5, 1.2);
        else if (type === 'hood') geom = new THREE.BoxGeometry(4.5, 0.3, 4.5);
        else geom = new THREE.BoxGeometry(1 + Math.random()*2, 0.2, 1 + Math.random()*2); 
        
        let mat = new THREE.MeshLambertMaterial({ color: color, side: THREE.DoubleSide });
        this.mesh = new THREE.Mesh(geom, mat);
        
        let groundY = getTrackHeightAtPos(this.pos);
        this.mesh.position.set(pos.x, groundY + 4, -pos.y);
        scene.add(this.mesh);
    }
    update(dt) {
        this.pos = this.pos.add(this.vel.mult(dt));
        this.mesh.position.x = this.pos.x; this.mesh.position.z = -this.pos.y;
        
        let groundY = getTrackHeightAtPos(this.pos);
        this.velZ -= 150 * dt; 
