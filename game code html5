        this.spoilMesh = new THREE.Mesh(spoilGeo, this.paintMat);
        this.spoilMesh.position.set(-this.length/2 + 1, 6.5, 0);
        this.mesh.add(this.spoilMesh);

        this.wheels = [];
        const tireGeo = new THREE.TorusGeometry(1.6, 0.8, 12, 24);
        const rimGeo = new THREE.CylinderGeometry(1.5, 1.5, 1.7, 16); rimGeo.rotateX(Math.PI/2);
        const tireMat = new THREE.MeshLambertMaterial({ color: 0x111111 });
        const rimMat = new THREE.MeshLambertMaterial({ color: 0x555555 });
        const spokeMat = new THREE.MeshLambertMaterial({ color: 0x111111 });
        
        let wx = this.length * 0.3; let wz = this.width * 0.45;
        let wPositions = [ [wx, wz], [wx, -wz], [-wx, wz], [-wx, -wz] ];
        for (let p of wPositions) {
            let wGroup = new THREE.Group();
            let tire = new THREE.Mesh(tireGeo, tireMat); let rim = new THREE.Mesh(rimGeo, rimMat);
            
            let spokeGeo = new THREE.BoxGeometry(0.6, 2.8, 1.8);
            let spoke1 = new THREE.Mesh(spokeGeo, spokeMat); let spoke2 = new THREE.Mesh(spokeGeo, spokeMat); spoke2.rotation.y = Math.PI / 2;
            rim.add(spoke1); rim.add(spoke2); wGroup.add(tire); wGroup.add(rim);
            wGroup.position.set(p[0], 2, p[1]); this.mesh.add(wGroup); this.wheels.push(wGroup);
        }
        scene.add(this.mesh);
    }

    getCorners() {
        let cos = Math.cos(this.angle); let sin = Math.sin(this.angle);
        let hw = this.width / 2; let hl = this.length / 2;
        return [
            this.pos.add(new Vec2(hl * cos - hw * sin, hl * sin + hw * cos)), 
            this.pos.add(new Vec2(hl * cos - (-hw) * sin, hl * sin + (-hw) * cos)), 
            this.pos.add(new Vec2(-hl * cos - (-hw) * sin, -hl * sin + (-hw) * cos)), 
            this.pos.add(new Vec2(-hl * cos - hw * sin, -hl * sin + hw * cos)) 
        ];
    }

    updatePhysics(dt, inputs) {
        if (this.health <= 0 && !this.isAirborne) return; 
        let forward = new Vec2(Math.cos(this.angle), Math.sin(this.angle));
        let right = new Vec2(-Math.sin(this.angle), Math.cos(this.angle));
        let forwardVel = this.vel.dot(forward); let lateralVel = this.vel.dot(right); let speed = this.vel.mag();

        for(let w of this.wheels) w.rotation.z -= forwardVel * dt * 0.05;

        let speedMps = forwardVel / METER;
        if (speedMps > 5 && !this.isAirborne) {
            this.fuel -= (inputs.throttle ? 1 : 0.2) * dt * 0.25; 
            let slipAngle = Math.atan2(lateralVel, Math.abs(forwardVel) + 1); 
            this.tires -= (Math.abs(slipAngle) * 5 + 0.1) * dt; 
        }
        this.fuel = Math.max(0, this.fuel); this.tires = Math.max(0, this.tires);

        // Exhaust backfires when lifting off throttle
        if (!this.isAirborne && !inputs.throttle && (speed * 0.223694) > 100 && Math.random() < 0.04) {
            let backfirePos = this.pos.sub(forward.mult(this.length/2)).add(right.mult(-this.width/2));
            spawnSparks(backfirePos, right.mult(-1), 10);
        }

        // PHYSICAL AERODYNAMIC BLOWOVER MODEL
        if (!this.isAirborne && speed > 130) {
            let velocityAngle = Math.atan2(this.vel.y, this.vel.x);
            let yawRelative = Math.abs(this.angle - velocityAngle);
            while(yawRelative > Math.PI) yawRelative -= Math.PI * 2;
            yawRelative = Math.abs(yawRelative);
            
            let liftCoeff = 0;
            if (yawRelative > Math.PI * 0.3 && yawRelative < Math.PI * 0.7) {
                liftCoeff = 0.9; // Sideways aerodynamic lift (huge sail area)
            } else if (yawRelative > Math.PI * 0.7) {
                liftCoeff = 0.7; // Backwards aerodynamic lift
            }
            
            let simSpeedMps = speed / METER;
            let liftForce = 0.5 * 1.2 * simSpeedMps * simSpeedMps * liftCoeff * 10; // F = 0.5 * rho * v^2 * Cl * A
            let gravityForce = 1500 * 9.8; 
            
            if (liftForce > gravityForce * 0.7 && Math.random() < 0.04) { 
                this.isAirborne = true;
                this.velZ = (liftForce / 1500) * 1.6; 
                this.pitchVel = (Math.random() - 0.5) * 8;
                this.rollVel = (yawRelative < Math.PI * 0.7) ? (lateralVel > 0 ? -1 : 1) * 16 : (Math.random() - 0.5) * 12;
            }
        }

        if (this.isAirborne) {
            this.velZ -= 350 * dt; this.heightZ += this.velZ * dt; this.pitch += this.pitchVel * dt; this.roll += this.rollVel * dt;
            this.vel = this.vel.add(this.vel.mult(-0.8 * dt)); this.pos = this.pos.add(this.vel.mult(dt)); this.angle += this.angularVel * dt;

            // Deform hood/spoiler continuously while tumbling
            if (Math.random() < 0.2) {
                let deformNormal = new Vec2((Math.random()-0.5)*2, (Math.random()-0.5)*2).normalize();
                applyDeformation(this, this.pos.add(deformNormal.mult(20)), 20000, deformNormal);
            }

            if (this.heightZ <= 0) { 
                this.heightZ = 0; this.velZ = Math.abs(this.velZ) * 0.5; this.vel = this.vel.mult(0.6); 
                this.pitchVel *= 0.6; this.rollVel *= 0.6;
                
                this.health -= 35;
                if (this.health < 50) this.damaged = true;
                spawnSparks(this.pos, new Vec2(0,0), 40);
                
                // Keep rolling if velocity is still massive
                if (this.vel.mag() > 50 && Math.abs(this.rollVel) > 2) {
                    this.velZ += 15; 
                } else if (this.velZ < 10) {
                    this.isAirborne = false; this.velZ = 0; this.pitch = 0; this.roll = 0;
                }
            }
        } else {
            let dragMult = 1.0 - (this.draftingAmount * 0.7); 
            let draftBoost = this.draftingAmount * 30000; 
            
            let tractionForce = 0;
            if (inputs.throttle && this.fuel > 0) tractionForce = (this.engineForce + draftBoost) * (this.damaged ? 0.6 : 1.0);
            else if (inputs.brake) tractionForce = -this.brakingForce * Math.sign(forwardVel);

            let dragForce = -this.airDrag * dragMult * forwardVel * Math.abs(forwardVel);
            let rollingForce = -this.rollingResist * forwardVel;
            let totalForwardForce = tractionForce + dragForce + rollingForce;

            let slipAngle = Math.atan2(lateralVel, Math.abs(forwardVel) + 1); 
            let lateralForce = -slipAngle * this.corneringStiffness * Math.abs(forwardVel);
            
            let activeMaxGrip = 55000 * (0.6 + 0.4 * (this.tires/100));
            let downforce = speed * 350;
            let gripLimit = activeMaxGrip + downforce;
            
            let isMovingSideways = Math.abs(slipAngle) > 0.2;
            if (Math.abs(lateralForce) > gripLimit) {
                if (isMovingSideways) { lateralForce = Math.sign(lateralForce) * gripLimit * 0.6; if (forwardVel > 80) spawnSmoke(this.pos, this.vel); } 
                else lateralForce = Math.sign(lateralForce) * gripLimit;
            }

            if (!isMovingSideways && speed > 20) lateralForce -= lateralVel * 500; 

            let accelF = forward.mult(totalForwardForce / this.mass);
            let accelL = right.mult(lateralForce / this.mass);
            this.vel = this.vel.add(accelF.mult(dt)).add(accelL.mult(dt));

            if (Math.abs(forwardVel) > 1) {
                let turnRadius = this.length / Math.sin(Math.max(0.01, Math.abs(inputs.steer)));
                let maxTurnRate = forwardVel / turnRadius;
                let targetAngularVel = inputs.steer * Math.min(Math.abs(maxTurnRate), 1.2); 
                let gripFactor = 1.0 - Math.min(1.0, Math.abs(lateralVel) / 200); 
                this.angularVel = this.angularVel * 0.85 + targetAngularVel * 0.05 * gripFactor; 
